[user]
    name = Matt Sweeney
    email = mattswe@gmail.com

[includeIf "gitdir:~/src/"]
    path = ~/src/.gitconfig

[color]
    diff = auto
    status = auto
    branch = auto
    interactive = auto

[core]
    excludesfile = ~/.gitignore

[branch]
    autosetuprebase = always

[diff]
    compactionHeuristic = true

[init]
	defaultBranch = main
